# SQL Server Connection
DB_SERVER=localhost
# DB_PORT=1433          # Optional — omit for named instances using SQL Browser
DB_DATABASE=YourDatabase
DB_USER=mcp_readonly
DB_PASSWORD=YourSecurePassword
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# MCP Server — each instance MUST use a unique port
MCP_PORT=3002
